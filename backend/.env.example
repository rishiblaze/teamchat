# Firebase (service account JSON path or base64 for Cloud Run)
GOOGLE_APPLICATION_CREDENTIALS=path/to/serviceAccountKey.json
# Or set FIREBASE_SERVICE_ACCOUNT_JSON with base64-encoded JSON in production

# GCP project for Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1

# Optional: limit context messages
AI_CONTEXT_MESSAGE_LIMIT=50
