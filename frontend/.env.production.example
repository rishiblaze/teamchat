# Copy to .env.production and fill with your deployed values.
# Used when running: npm run build (e.g. for Firebase Hosting deploy)

# Your Cloud Run backend URL (no trailing slash)
VITE_API_URL=https://teamchat-api-xxxxx-uc.a.run.app

# From Firebase Console → Project settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
